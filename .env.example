# SMS Price Tracker — Environment Variables
# Copy this to .env.local and fill in your values

# ── Frontend (Vite) ──────────────────────────────────────────
# Supabase project URL and anonymous key (RLS enforced)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Backend (Vercel Serverless Functions) ────────────────────
# Supabase service role key (bypasses RLS — server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── Data Pipeline (Python scrapers — GitHub Secrets) ─────────
# Vonage (free account: dashboard.nexmo.com)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# MessageBird / Bird (free account: dashboard.messagebird.com)
MESSAGEBIRD_ACCESS_KEY=

# Plivo (free account: console.plivo.com)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# ClickSend (free account: dashboard.clicksend.com)
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
